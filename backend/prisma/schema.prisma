generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                        String            @default(uuid())          @id
  username                  String
  email                     String            @unique
  password                  String
  verified                  Boolean           @default(false)
  otps                      Otp[]
  reports                   InterviewReport[] //interview relation
}

model Otp {
  id                        String            @default(uuid())         @id
  otpHash                   String
  email                     String
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  userId                    String
  user                      User              @relation(fields: [userId], references: [id])
}

model Blacklist {
  id                        String            @default(uuid())          @id
  jti                       String            @unique
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  //expiresAt for cleanup(crone cleanup)
}

model InterviewReport { //report have multiple arrays
  id                        String            @default(uuid())          @id
  jobDescription            String
  resume                    String
  selfDescription           String
  matchScore                Int
  title                     String

  technicalQuestion         TechnicalQuestion[]
  behavioralQuestions       BehavioralQuestion[]
  skillGaps                 SkillGap[]
  preparationPlan           PreparationPlan[]  

  // Relation to user
  userId                    String
  user                      User              @relation(fields: [userId], references: [id])
}

model TechnicalQuestion {
  id                        String            @default(uuid())          @id
  question                  String
  intention                 String
  answer                    String

  interviewReportId         String
  interviewReport           InterviewReport   @relation(fields: [interviewReportId], references: [id])
}

model BehavioralQuestion {
  id                        String            @default(uuid())          @id
  question                  String
  intention                 String
  answer                    String
  
  interviewReportId         String
  interviewReport           InterviewReport   @relation(fields: [interviewReportId], references: [id])
}

model SkillGap {
  id                        String            @default(uuid())          @id
  skill                     String
  severity                  String
  
  interviewReportId         String
  interviewReport           InterviewReport   @relation(fields: [interviewReportId], references: [id])
}

model PreparationPlan {
  id                        String            @default(uuid())          @id
  day                       Int
  focus                     String
  task                      String[]
  
  interviewReportId         String
  interviewReport           InterviewReport   @relation(fields: [interviewReportId], references: [id])
}